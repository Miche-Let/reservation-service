### Scenario 1-B: Consumer Reservation (Waiting Check -> Reservation)
### 사전 조건: Scenario 1-A 실행 완료 (waitingToken 획득 상태)
### 이 파일은 대기 상태 확인부터 실제 예약 생성 및 조회까지 수행합니다.

### [STEP 7] 대기 상태 확인 (WAIT 10 SECONDS IF STATUS IS 'WAITING')
### 주의: 스케줄러가 10초마다 WAITING → ACTIVE 전환함
### 만약 status가 WAITING 이라면, 10초 후 이 단계를 다시 실행하세요.
GET {{gateway}}/api/v1/waitings/status?token={{waitingToken}}
Authorization: Bearer {{accessToken}}

> {%
  client.test("대기 상태 조회 성공", function() {
    client.assert(response.status === 200, "Expected 200 OK but got " + response.status);
    if (response.body && response.body.data) {
        var status = response.body.data.status;
        if (status !== "ACTIVE") {
            client.log("!!! 현재 상태: " + status + ". 아직 ACTIVE가 아닙니다. 10초 후 이 STEP을 다시 실행하세요. !!!");
        } else {
            client.log(">>> 현재 상태: ACTIVE. 이제 다음 STEP(8번)으로 진행 가능합니다. <<<");
        }
    }
  });
%}

###

### [STEP 8] 월별 예약 가능 달력 조회 (2026년 6월)
GET {{gateway}}/api/v1/restaurants/{{restaurantId}}/time-slots/calendar?year=2026&month=6
Authorization: Bearer {{accessToken}}

> {%
  client.test("월별 달력 조회 성공", function() {
    client.assert(response.status === 200, "Expected 200 OK");
  });
  var slots = response.body.data;
  var opened = slots.filter(function(s) { return s.status === "OPENED"; });
  if (opened.length > 0) {
    client.global.set("targetDate", opened[0].date);
    client.log("예약 가능 날짜: " + opened[0].date);
  }
%}

###

### [STEP 9] 특정 날짜 타임슬롯 목록 조회 → timeSlotId, slotStartTime 추출
GET {{gateway}}/api/v1/restaurants/{{restaurantId}}/time-slots?targetDate={{targetDate}}
Authorization: Bearer {{accessToken}}

> {%
  client.test("타임슬롯 목록 조회 성공", function() {
    client.assert(response.status === 200, "Expected 200 OK");
    client.assert(response.body.data.length > 0, "타임슬롯 1개 이상 존재 확인");
  });
  var available = response.body.data.filter(function(s) {
    return s.remainingCapacity > 0;
  });
  if (available.length > 0) {
    client.global.set("timeSlotId", available[0].timeSlotId);
    client.global.set("slotStartTime", available[0].startTime);
    client.log("선택된 타임슬롯: " + available[0].timeSlotId + " (" + available[0].startTime + ")");
  }
%}

###

### [STEP 10] 예약 생성
### 전제: STEP 7에서 대기 상태가 ACTIVE 인 것을 확인한 후 실행
POST {{gateway}}/api/v1/reservations
Authorization: Bearer {{accessToken}}
X-Waiting-Token: {{waitingToken}}
Content-Type: application/json

{
  "restaurantId": "{{restaurantId}}",
  "timeSlotId": "{{timeSlotId}}",
  "reservedDate": "{{targetDate}}",
  "slotStartTime": "{{slotStartTime}}",
  "guestCount": 2,
  "courses": [
    {
      "courseId": "{{courseId}}",
      "quantity": 2,
      "unitPrice": {{courseUnitPrice}}
    }
  ]
}

> {%
  client.test("예약 생성 성공", function() {
    client.assert(response.status === 201, "Expected 201 Created but got " + response.status);
    if (response.body && response.body.data) {
        client.assert(response.body.data.reservationId !== undefined, "reservationId 반환 확인");
    }
  });
  if (response.body && response.body.data) {
      client.global.set("reservationId", response.body.data.reservationId);
  }
%}

###

### [STEP 11] 예약 상세 조회
GET {{gateway}}/api/v1/reservations/{{reservationId}}
Authorization: Bearer {{accessToken}}

> {%
  client.test("예약 상세 조회 성공", function() {
    client.assert(response.status === 200, "Expected 200 OK");
    client.assert(response.body.data.status === "CONFIRMED", "예약 상태 CONFIRMED 확인");
  });
%}

###

### [STEP 12] 내 예약 목록 조회
GET {{gateway}}/api/v1/reservations?page=0&size=10
Authorization: Bearer {{accessToken}}

> {%
  client.test("예약 목록 조회 성공", function() {
    client.assert(response.status === 200, "Expected 200 OK");
    client.assert(response.body.data.content.length > 0, "예약 1개 이상 존재 확인");
  });
%}
